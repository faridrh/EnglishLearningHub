<section class="page-header">
  <div class="container">
    <h1 class="page-title">Lesson 10 - Simple Questions & Short Answers</h1>
    <p class="page-description">Ask and answer basic questions</p>
  </div>
</section>

<section class="grammar-topics">
  <div class="container">
    <h2 class="section-title">Goal</h2>
    <div class="topics-grid">
      <div class="topic-card">
        <p class="topic-description">Ask and answer basic questions.</p>
      </div>
    </div>

    <h2 class="section-title">Content</h2>
    <div class="topics-grid">
      <div class="topic-card">
        <h3 class="topic-title">1) What Is This?</h3>
        <p class="topic-description">What is this?</p>
        <button type="button" class="button" data-speak="What is this?" style="margin-top: 10px;">Read Question</button>
      </div>

      <div class="topic-card">
        <h3 class="topic-title">2) Where Are You From?</h3>
        <p class="topic-description">Where are you from?</p>
        <button type="button" class="button" data-speak="Where are you from?" style="margin-top: 10px;">Read Question</button>
      </div>

      <div class="topic-card">
        <h3 class="topic-title">3) Do You Like...?</h3>
        <p class="topic-description">Do you like...?</p>
        <button type="button" class="button" data-speak="Do you like tea?" style="margin-top: 10px;">Read Question</button>
      </div>

      <div class="topic-card">
        <h3 class="topic-title">4) Short Answers</h3>
        <p class="topic-description">Yes, I do. / No, I don't.</p>
        <button type="button" class="button" data-speak="Yes, I do. No, I don't." style="margin-top: 10px;">Read Answers</button>
      </div>
    </div>
  </div>
</section>

<section class="tips-section">
  <div class="container">
    <h2 class="section-title">Practice</h2>
    <div class="tips-grid">
      <div class="tip-card">
        <div class="tip-icon"><i class="fas fa-question-circle"></i></div>
        <h3>5 Question-Answer Pairs</h3>
        <p>Practice five short question and answer pairs with a partner.</p>
      </div>
    </div>
  </div>
</section>

<section class="grammar-topics">
  <div class="container">
    <h2 class="section-title">Sentence Building</h2>
    <div class="topics-grid">
      <div class="topic-card">
        <h3 class="topic-title">Build a Q&A pair</h3>
        <p class="topic-description">Type a topic and choose a short answer.</p>
        <div style="margin-top: 14px; display: flex; gap: 10px; flex-wrap: wrap; align-items: center;">
          <label for="lesson-10-topic-input" style="font-weight: 600;">Topic:</label>
          <input id="lesson-10-topic-input" type="text" placeholder="tea" style="padding: 10px 12px; border: 1px solid #cbd5e1; border-radius: 6px; min-width: 140px;">
          <label for="lesson-10-answer-select" style="font-weight: 600;">Answer:</label>
          <select id="lesson-10-answer-select" style="padding: 10px 12px; border: 1px solid #cbd5e1; border-radius: 6px; min-width: 150px;">
            <option value="Yes, I do.">Yes, I do.</option>
            <option value="No, I don't.">No, I don't.</option>
          </select>
          <button type="button" class="button" id="lesson-10-build-sentence">Build Pair</button>
        </div>
        <p style="margin-top: 14px; font-size: 1.05rem;">Q: Do you like <strong><span id="lesson-10-topic-output">_____</span></strong>?<br>A: <strong><span id="lesson-10-answer-output">Yes, I do.</span></strong></p>
        <p id="lesson-10-sentence-feedback" style="margin-top: 12px; color: #475569; font-size: 0.95rem;"></p>
      </div>
    </div>
  </div>
</section>

<script>
(function () {
  const speakButtons = document.querySelectorAll('[data-speak]');
  const topicInput = document.getElementById('lesson-10-topic-input');
  const answerSelect = document.getElementById('lesson-10-answer-select');
  const topicOutput = document.getElementById('lesson-10-topic-output');
  const answerOutput = document.getElementById('lesson-10-answer-output');
  const feedback = document.getElementById('lesson-10-sentence-feedback');
  const buildButton = document.getElementById('lesson-10-build-sentence');

  function supported() {
    return typeof window !== 'undefined' && 'speechSynthesis' in window && 'SpeechSynthesisUtterance' in window;
  }

  function speak(text) {
    if (!supported()) return;
    window.speechSynthesis.cancel();
    const utterance = new SpeechSynthesisUtterance(text);
    utterance.lang = 'en-US';
    utterance.rate = 0.9;
    utterance.pitch = 1;
    window.speechSynthesis.speak(utterance);
  }

  function updateBuilder() {
    const topic = topicInput ? topicInput.value.trim() : '';
    const answer = answerSelect ? answerSelect.value : 'Yes, I do.';
    if (topicOutput) topicOutput.textContent = topic || '_____';
    if (answerOutput) answerOutput.textContent = answer;

    if (feedback) {
      if (topic) {
        feedback.textContent = 'Built pair: Do you like ' + topic + '? ' + answer;
      } else {
        feedback.textContent = 'Type a topic to build the question.';
      }
    }

    if (topic) {
      speak('Do you like ' + topic + '? ' + answer);
    }
  }

  speakButtons.forEach(function (button) {
    button.addEventListener('click', function () {
      speak(button.getAttribute('data-speak') || '');
    });
  });

  if (buildButton) {
    buildButton.addEventListener('click', updateBuilder);
  }
})();
</script>

