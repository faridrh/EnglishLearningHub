          <label for="lesson-2-name-input" style="font-weight: 600;">Your name:</label>
          <input id="lesson-2-name-input" type="text" placeholder="Farid" style="padding: 10px 12px; border: 1px solid #cbd5e1; border-radius: 6px; min-width: 220px;">
          <button type="button" class="button" id="lesson-2-build-sentence">Build Sentence</button>
        </div>

        <p style="margin-top: 14px; font-size: 1.05rem;">
          My name is <strong><span id="lesson-2-name-output">_____</span></strong>.
        </p>
        <p style="margin-top: 10px; color: #475569; font-size: 0.95rem;">Example: My name is Farid.</p>
