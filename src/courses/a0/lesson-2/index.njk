      <div class="topic-card">
        <h3 class="topic-title">Lesson Audio Practice</h3>
        <p class="topic-description">Use your browser speaker to hear the lesson. If no sound plays, your browser may not support speech synthesis.</p>

        <div class="button-group" style="display: flex; flex-wrap: wrap; gap: 10px; margin-top: 12px;">
          <button type="button" class="button button-secondary" id="tts-stop">Stop Audio</button>
        </div>

        <div style="margin-top: 14px; display: flex; gap: 10px; flex-wrap: wrap; align-items: center;">
          <label for="name-spell-input" style="font-weight: 600;">Say your name:</label>
          <input id="name-spell-input" type="text" placeholder="Type your name" style="padding: 10px 12px; border: 1px solid #cbd5e1; border-radius: 6px; min-width: 220px;">
          <button type="button" class="button" id="speak-name">Read My Name</button>
        </div>

        <p id="tts-status" style="margin-top: 12px; color: #475569; font-size: 0.95rem;"></p>
      </div>
    </div>
  </div>
</section>

<script>
(function () {
  const statusEl = document.getElementById('tts-status');
  const speakButtons = document.querySelectorAll('[data-speak]');
  const stopButton = document.getElementById('tts-stop');
  const speakNameButton = document.getElementById('speak-name');
  const nameInput = document.getElementById('name-spell-input');

  function setStatus(message) {
    if (statusEl) statusEl.textContent = message;
  }

  function supported() {
    return typeof window !== 'undefined' && 'speechSynthesis' in window && 'SpeechSynthesisUtterance' in window;
  }

  function speak(text) {
    if (!supported()) {
      setStatus('Browser TTS is not supported on this device.');
      return;
    }

    window.speechSynthesis.cancel();
    const utterance = new SpeechSynthesisUtterance(text);
    utterance.lang = 'en-US';
    utterance.rate = 0.9;
    utterance.pitch = 1;
    utterance.onstart = function () {
      setStatus('Playing audio...');
    };
    utterance.onend = function () {
      setStatus('Audio finished.');
    };
    utterance.onerror = function () {
      setStatus('Could not play audio. Please try again.');
    };
    window.speechSynthesis.speak(utterance);
  }

  function spellName(nameValue) {
    const trimmed = nameValue.trim();
    if (!trimmed) {
      setStatus('Type your name first.');
      return;
    }

    const letters = trimmed.toUpperCase().replace(/\s+/g, '').split('').join(', ');
    speak(letters);
  }

  speakButtons.forEach(function (button) {
    button.addEventListener('click', function () {
      speak(button.getAttribute('data-speak'));
    });
  });

  if (speakNameButton) {
    speakNameButton.addEventListener('click', function () {
      spellName(nameInput ? nameInput.value : '');
    });
  }

  if (stopButton) {
    stopButton.addEventListener('click', function () {
      if (supported()) {
        window.speechSynthesis.cancel();
        setStatus('Audio stopped.');
      }
    });
  }

  if (!supported()) {
    setStatus('Browser TTS is not supported on this device.');
  } else {
    setStatus('Click any button to hear the lesson.');
  }
})();
</script>

