---
layout: layouts/base.njk
title: A0 English Course
description: Start from zero with the A0 English course for complete beginners.
courseLevel: A0
---

<section class="page-header">
  <div class="container">
    <h1 class="page-title">A0 English Course</h1>
    <p class="page-description">Start from zero and build your first English words and sentences</p>
  </div>
</section>

<section class="grammar-topics">
  <div class="container">
    <h2 class="section-title">A0 Lessons</h2>
    <div class="topics-grid">
      {% for lesson in a0Lessons %}
      <div class="topic-card">
        <h3 class="topic-title">{{ lesson.indexTitle }}</h3>
        <p class="topic-description">{{ lesson.indexDescription }}</p>
        <a href="/courses/a0/lesson-{{ lesson.number }}/" class="topic-link">Start Lesson {{ lesson.number }}</a>
      </div>
      {% endfor %}
    </div>

    <div class="section-footer">
      {% for lesson in a0Lessons %}
      <a href="/courses/a0/lesson-{{ lesson.number }}/" class="button{% if loop.index % 2 == 0 %} button-secondary{% endif %}">Open Lesson {{ lesson.number }}: {{ lesson.title }}</a>
      {% endfor %}
    </div>
  </div>
</section>

<section class="cta-section">
  <div class="container">
    <h2 class="cta-title">Ready to Continue?</h2>
    <p class="cta-description">After finishing A0, continue your journey with A1.</p>
    <div class="cta-buttons">
      <a href="/courses/a1/" class="button button-primary">Go to A1 Course</a>
      <a href="/courses/" class="button button-secondary">View All Courses</a>
    </div>
  </div>
</section>
