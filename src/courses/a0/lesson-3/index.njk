<script>
(function () {
  const speakButtons = document.querySelectorAll('[data-speak]');
  const builderInput = document.getElementById('lesson-3-age-input');
  const builderOutput = document.getElementById('lesson-3-age-output');
  const builderFeedback = document.getElementById('lesson-3-sentence-feedback');
  const builderButton = document.getElementById('lesson-3-build-sentence');

  function supported() {
    return typeof window !== 'undefined' && 'speechSynthesis' in window && 'SpeechSynthesisUtterance' in window;
  }

  function speak(text) {
    if (!supported()) return;

    window.speechSynthesis.cancel();
    const utterance = new SpeechSynthesisUtterance(text);
    utterance.lang = 'en-US';
    utterance.rate = 0.9;
    utterance.pitch = 1;
    window.speechSynthesis.speak(utterance);
  }

  function speakBuilderSentence(value) {
    const trimmed = value.trim();
    if (!trimmed) {
      return;
    }

    speak('I am ' + trimmed + ' years old.');
  }

  function updateBuilder() {
    const value = builderInput ? builderInput.value.trim() : '';
    if (builderOutput) {
      builderOutput.textContent = value || '___';
    }
    if (builderFeedback) {
      builderFeedback.textContent = value
        ? 'Built sentence: I am ' + value + ' years old.'
        : 'Type a number to build the sentence.';
    }
  }

  speakButtons.forEach(function (button) {
    button.addEventListener('click', function () {
      speak(button.getAttribute('data-speak') || '');
    });
  });

  if (builderInput) {
    builderInput.addEventListener('input', updateBuilder);
  }

  if (builderButton) {
    builderButton.addEventListener('click', function () {
      updateBuilder();
      speakBuilderSentence(builderInput ? builderInput.value : '');
    });
  }

  updateBuilder();
})();
</script>

