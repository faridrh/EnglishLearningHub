<section class="page-header">
  <div class="container">
    <h1 class="page-title">Lesson 5 - Family & People</h1>
    <p class="page-description">Talk about family members</p>
  </div>
</section>

<section class="grammar-topics">
  <div class="container">
    <h2 class="section-title">Goal</h2>
    <div class="topics-grid">
      <div class="topic-card">
        <p class="topic-description">Talk about family members.</p>
      </div>
    </div>

    <h2 class="section-title">Content</h2>
    <div class="topics-grid">
      <div class="topic-card">
        <h3 class="topic-title">1) Family Words</h3>
        <p class="topic-description">mother, father, brother, sister, friend</p>
        <button type="button" class="button" data-speak="mother, father, brother, sister, friend" style="margin-top: 10px;">Read Family Words</button>
      </div>

      <div class="topic-card">
        <h3 class="topic-title">2) This Is My...</h3>
        <p class="topic-description">This is my mother. This is my friend.</p>
        <button type="button" class="button" data-speak="This is my mother. This is my friend." style="margin-top: 10px;">Read This Is My</button>
      </div>

      <div class="topic-card">
        <h3 class="topic-title">3) He/She Is My...</h3>
        <p class="topic-description">He is my brother. She is my sister.</p>
        <button type="button" class="button" data-speak="He is my brother. She is my sister." style="margin-top: 10px;">Read He/She Is My</button>
      </div>
    </div>
  </div>
</section>

<section class="tips-section">
  <div class="container">
    <h2 class="section-title">Practice</h2>
    <div class="tips-grid">
      <div class="tip-card">
        <div class="tip-icon"><i class="fas fa-users"></i></div>
        <h3>Introduce 3 Family Members</h3>
        <p>Example: This is my mother. This is my father. This is my sister.</p>
        <button type="button" class="button" data-speak="This is my mother. This is my father. This is my sister." style="margin-top: 10px;">Read Example</button>
      </div>
    </div>
  </div>
</section>

<section class="grammar-topics">
  <div class="container">
    <h2 class="section-title">Sentence Building</h2>
    <div class="topics-grid">
      <div class="topic-card">
        <h3 class="topic-title">Build your family sentence</h3>
        <p class="topic-description">Type a family member to complete the sentence.</p>
        <div style="margin-top: 14px; display: flex; gap: 10px; flex-wrap: wrap; align-items: center;">
          <label for="lesson-5-family-input" style="font-weight: 600;">Family member:</label>
          <input id="lesson-5-family-input" type="text" placeholder="brother" style="padding: 10px 12px; border: 1px solid #cbd5e1; border-radius: 6px; min-width: 220px;">
          <button type="button" class="button" id="lesson-5-build-sentence">Build Sentence</button>
        </div>
        <p style="margin-top: 14px; font-size: 1.05rem;">This is my <strong><span id="lesson-5-family-output">_____</span></strong>.</p>
        <p id="lesson-5-sentence-feedback" style="margin-top: 12px; color: #475569; font-size: 0.95rem;"></p>
      </div>
    </div>
  </div>
</section>

<script>
(function () {
  const speakButtons = document.querySelectorAll('[data-speak]');
  const familyInput = document.getElementById('lesson-5-family-input');
  const familyOutput = document.getElementById('lesson-5-family-output');
  const feedback = document.getElementById('lesson-5-sentence-feedback');
  const buildButton = document.getElementById('lesson-5-build-sentence');

  function supported() {
    return typeof window !== 'undefined' && 'speechSynthesis' in window && 'SpeechSynthesisUtterance' in window;
  }

  function speak(text) {
    if (!supported()) return;
    window.speechSynthesis.cancel();
    const utterance = new SpeechSynthesisUtterance(text);
    utterance.lang = 'en-US';
    utterance.rate = 0.9;
    utterance.pitch = 1;
    window.speechSynthesis.speak(utterance);
  }

  function updateBuilder() {
    const value = familyInput ? familyInput.value.trim() : '';
    if (familyOutput) familyOutput.textContent = value || '_____';

    if (feedback) {
      feedback.textContent = value
        ? 'Built sentence: This is my ' + value + '.'
        : 'Type a family member to build the sentence.';
    }

    if (value) {
      speak('This is my ' + value + '.');
    }
  }

  speakButtons.forEach(function (button) {
    button.addEventListener('click', function () {
      speak(button.getAttribute('data-speak') || '');
    });
  });

  if (buildButton) {
    buildButton.addEventListener('click', updateBuilder);
  }
})();
</script>

