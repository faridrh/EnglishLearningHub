<section class="grammar-topics">
  <div class="container">
    <h2 class="section-title">Sentence Building</h2>
    <div class="topics-grid">
      <div class="topic-card">
        <h3 class="topic-title">Build with I + verb</h3>
        <p class="topic-description">Type one verb and one object.</p>
        <div style="margin-top: 14px; display: flex; gap: 10px; flex-wrap: wrap; align-items: center;">
          <label for="lesson-7-verb-input" style="font-weight: 600;">Verb:</label>
          <input id="lesson-7-verb-input" type="text" placeholder="like" style="padding: 10px 12px; border: 1px solid #cbd5e1; border-radius: 6px; min-width: 160px;">
          <label for="lesson-7-object-input" style="font-weight: 600;">Object:</label>
          <input id="lesson-7-object-input" type="text" placeholder="tea" style="padding: 10px 12px; border: 1px solid #cbd5e1; border-radius: 6px; min-width: 160px;">
          <button type="button" class="button" id="lesson-7-build-sentence">Build Sentence</button>
        </div>
        <p style="margin-top: 14px; font-size: 1.05rem;">I <strong><span id="lesson-7-verb-output">_____</span></strong> <strong><span id="lesson-7-object-output">_____</span></strong>.</p>
        <p id="lesson-7-sentence-feedback" style="margin-top: 12px; color: #475569; font-size: 0.95rem;"></p>
      </div>
    </div>
  </div>
</section>

<script>
(function () {
  const speakButtons = document.querySelectorAll('[data-speak]');
  const verbInput = document.getElementById('lesson-7-verb-input');
  const objectInput = document.getElementById('lesson-7-object-input');
  const verbOutput = document.getElementById('lesson-7-verb-output');
  const objectOutput = document.getElementById('lesson-7-object-output');
  const feedback = document.getElementById('lesson-7-sentence-feedback');
  const buildButton = document.getElementById('lesson-7-build-sentence');

  function supported() {
    return typeof window !== 'undefined' && 'speechSynthesis' in window && 'SpeechSynthesisUtterance' in window;
  }

  function speak(text) {
    if (!supported()) return;
    window.speechSynthesis.cancel();
    const utterance = new SpeechSynthesisUtterance(text);
    utterance.lang = 'en-US';
    utterance.rate = 0.9;
    utterance.pitch = 1;
    window.speechSynthesis.speak(utterance);
  }

  function updateBuilder() {
    const verb = verbInput ? verbInput.value.trim() : '';
    const object = objectInput ? objectInput.value.trim() : '';
    if (verbOutput) verbOutput.textContent = verb || '_____';
    if (objectOutput) objectOutput.textContent = object || '_____';

    if (feedback) {
      if (verb && object) {
        feedback.textContent = 'Built sentence: I ' + verb + ' ' + object + '.';
      } else {
        feedback.textContent = 'Type a verb and an object.';
      }
    }

    if (verb && object) {
      speak('I ' + verb + ' ' + object + '.');
    }
  }

  speakButtons.forEach(function (button) {
    button.addEventListener('click', function () {
      speak(button.getAttribute('data-speak') || '');
    });
  });

  if (buildButton) {
    buildButton.addEventListener('click', updateBuilder);
  }
})();
</script>

