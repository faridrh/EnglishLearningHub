<section class="grammar-topics">
  <div class="container">
    <h2 class="section-title">Sentence Building</h2>
    <div class="topics-grid">
      <div class="topic-card">
        <h3 class="topic-title">Build one routine sentence</h3>
        <p class="topic-description">Type one action and one day part.</p>
        <div style="margin-top: 14px; display: flex; gap: 10px; flex-wrap: wrap; align-items: center;">
          <label for="lesson-9-action-input" style="font-weight: 600;">Action:</label>
          <input id="lesson-9-action-input" type="text" placeholder="wake up" style="padding: 10px 12px; border: 1px solid #cbd5e1; border-radius: 6px; min-width: 160px;">
          <label for="lesson-9-time-input" style="font-weight: 600;">Time:</label>
          <input id="lesson-9-time-input" type="text" placeholder="morning" style="padding: 10px 12px; border: 1px solid #cbd5e1; border-radius: 6px; min-width: 160px;">
          <button type="button" class="button" id="lesson-9-build-sentence">Build Sentence</button>
        </div>
        <p style="margin-top: 14px; font-size: 1.05rem;">I <strong><span id="lesson-9-action-output">_____</span></strong> in the <strong><span id="lesson-9-time-output">_____</span></strong>.</p>
        <p id="lesson-9-sentence-feedback" style="margin-top: 12px; color: #475569; font-size: 0.95rem;"></p>
      </div>
    </div>
  </div>
</section>

<script>
(function () {
  const speakButtons = document.querySelectorAll('[data-speak]');
  const actionInput = document.getElementById('lesson-9-action-input');
  const timeInput = document.getElementById('lesson-9-time-input');
  const actionOutput = document.getElementById('lesson-9-action-output');
  const timeOutput = document.getElementById('lesson-9-time-output');
  const feedback = document.getElementById('lesson-9-sentence-feedback');
  const buildButton = document.getElementById('lesson-9-build-sentence');

  function supported() {
    return typeof window !== 'undefined' && 'speechSynthesis' in window && 'SpeechSynthesisUtterance' in window;
  }

  function speak(text) {
    if (!supported()) return;
    window.speechSynthesis.cancel();
    const utterance = new SpeechSynthesisUtterance(text);
    utterance.lang = 'en-US';
    utterance.rate = 0.9;
    utterance.pitch = 1;
    window.speechSynthesis.speak(utterance);
  }

  function updateBuilder() {
    const action = actionInput ? actionInput.value.trim() : '';
    const time = timeInput ? timeInput.value.trim() : '';
    if (actionOutput) actionOutput.textContent = action || '_____';
    if (timeOutput) timeOutput.textContent = time || '_____';

    if (feedback) {
      if (action && time) {
        feedback.textContent = 'Built sentence: I ' + action + ' in the ' + time + '.';
      } else {
        feedback.textContent = 'Type an action and a day part.';
      }
    }

    if (action && time) {
      speak('I ' + action + ' in the ' + time + '.');
    }
  }

  speakButtons.forEach(function (button) {
    button.addEventListener('click', function () {
      speak(button.getAttribute('data-speak') || '');
    });
  });

  if (buildButton) {
    buildButton.addEventListener('click', updateBuilder);
  }
})();
</script>

