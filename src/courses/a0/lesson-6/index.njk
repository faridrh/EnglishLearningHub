</section>

<script>
(function () {
  const speakButtons = document.querySelectorAll('[data-speak]');
  const wordBank = document.getElementById('lesson-6-word-bank');
  const words = document.querySelectorAll('.lesson-6-word');
  const zones = document.querySelectorAll('.lesson-6-drop-zone');
  const zoneA = document.getElementById('lesson-6-zone-a');
  const zoneAn = document.getElementById('lesson-6-zone-an');
  const checkButton = document.getElementById('lesson-6-check');
  const resetButton = document.getElementById('lesson-6-reset');
  const feedback = document.getElementById('lesson-6-sentence-feedback');
  const initialOrder = Array.from(words).map(function (word) {
    return word.id;
  });
  let selectedWord = null;

  function supported() {
    return typeof window !== 'undefined' && 'speechSynthesis' in window && 'SpeechSynthesisUtterance' in window;
  }

  function speak(text) {
    if (!supported()) return;
    window.speechSynthesis.cancel();
    const utterance = new SpeechSynthesisUtterance(text);
    utterance.lang = 'en-US';
    utterance.rate = 0.9;
    utterance.pitch = 1;
    window.speechSynthesis.speak(utterance);
  }

  function clearWordStyles() {
    words.forEach(function (word) {
      word.style.outline = '';
      word.style.backgroundColor = '';
      word.style.borderColor = '';
      word.style.color = '';
    });
  }

  function moveWordToZone(word, zone) {
    const target = zone === 'a' ? zoneA : zoneAn;
    if (target) {
      target.appendChild(word);
    }
  }

  function setFeedback(message) {
    if (feedback) {
      feedback.textContent = message;
    }
  }

  function checkAnswers() {
    let correct = 0;
    let placed = 0;

    words.forEach(function (word) {
      const parentZone = word.closest('.lesson-6-drop-zone');
      if (!parentZone) {
        return;
      }

      placed += 1;
      const zoneArticle = parentZone.getAttribute('data-zone');
      const expected = word.getAttribute('data-article');

      if (zoneArticle === expected) {
        correct += 1;
        word.style.backgroundColor = '#dcfce7';
        word.style.borderColor = '#16a34a';
        word.style.color = '#166534';
      } else {
        word.style.backgroundColor = '#fee2e2';
        word.style.borderColor = '#dc2626';
        word.style.color = '#991b1b';
      }
    });

    if (placed < words.length) {
      setFeedback('Place all words into "a" or "an" first.');
      return;
    }

    if (correct === words.length) {
      setFeedback('Great job. All answers are correct.');
      speak('Great job. All answers are correct.');
    } else {
      setFeedback('You got ' + correct + ' out of ' + words.length + ' correct. Try again.');
    }
  }

  function resetExercise() {
    clearWordStyles();
    initialOrder.forEach(function (id) {
      const word = document.getElementById(id);
      if (wordBank && word) {
        wordBank.appendChild(word);
      }
    });
    selectedWord = null;
    setFeedback('Drag each word to the correct article box.');
  }

  speakButtons.forEach(function (button) {
    button.addEventListener('click', function () {
      speak(button.getAttribute('data-speak') || '');
    });
  });

  words.forEach(function (word) {
    word.addEventListener('dragstart', function (event) {
      event.dataTransfer.setData('text/plain', word.id);
    });

    word.addEventListener('click', function () {
      clearWordStyles();
      selectedWord = word;
      word.style.outline = '2px solid #1d4ed8';
    });
  });

  zones.forEach(function (zone) {
    zone.addEventListener('dragover', function (event) {
      event.preventDefault();
    });

    zone.addEventListener('drop', function (event) {
      event.preventDefault();
      const draggedId = event.dataTransfer.getData('text/plain');
      const draggedWord = document.getElementById(draggedId);
      if (draggedWord) {
        clearWordStyles();
        moveWordToZone(draggedWord, zone.getAttribute('data-zone'));
      }
    });

    zone.addEventListener('click', function () {
      if (selectedWord) {
        clearWordStyles();
        moveWordToZone(selectedWord, zone.getAttribute('data-zone'));
        selectedWord = null;
      }
    });
  });

  if (checkButton) {
    checkButton.addEventListener('click', checkAnswers);
  }

  if (resetButton) {
    resetButton.addEventListener('click', resetExercise);
  }

  resetExercise();
})();
</script>

