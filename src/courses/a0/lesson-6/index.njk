            <h4 style="margin: 0 0 8px;">a</h4>
            <div id="lesson-6-zone-a" style="display: flex; gap: 8px; flex-wrap: wrap;"></div>
          </div>
          <div class="lesson-6-drop-zone" data-zone="an" style="border: 2px dashed #94a3b8; border-radius: 10px; padding: 12px; min-height: 140px;">
            <h4 style="margin: 0 0 8px;">an</h4>
            <div id="lesson-6-zone-an" style="display: flex; gap: 8px; flex-wrap: wrap;"></div>
          </div>
        </div>

