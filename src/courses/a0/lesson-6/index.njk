          <button type="button" class="button button-secondary lesson-6-word" id="lesson-6-word-3" draggable="true" data-word="egg" data-article="an">egg</button>
          <button type="button" class="button button-secondary lesson-6-word" id="lesson-6-word-4" draggable="true" data-word="book" data-article="a">book</button>
